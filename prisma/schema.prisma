// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL_LOCAL")
}

model SuperAdmin {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  password      String
  createdAt     DateTime  @default(now())
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  password      String
  role          String    @default("user") // e.g., "user", "manager", "admin"
  companyName   String?   // Optional company name for the user
  location      String?   // Optional location of the user
  subscriptionType String? @default("free") // e.g., "free", "premium", "enterprise"
  createdAt     DateTime  @default(now())
  clients       Client[]
  sessions      Session[]
  accounts      Account[]
  payments      Payment[]
  historics     Historic[] // Relation to Historic
  notifications Notification[] // Relation to Notification
}

model Client {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  phone            String?
  email            String?   @unique
  registrationDate DateTime  @default(now())
  payments         Payment[]
  userId           String    @db.ObjectId
  user             User      @relation(fields: [userId], references: [id])
  historics        Historic[] // Added relation to Historic
  notifications    Notification[] // Added relation to Notification
}

model Notification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        String    // e.g., "CLIENT_REGISTERED", "PAYMENT_RECEIVED"
  message     String    // e.g., "John Doe has registered today"
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  // Optional relations to Client and Payment
  clientId    String?   @db.ObjectId
  client      Client?   @relation(fields: [clientId], references: [id])
  paymentId   String?   @db.ObjectId
  payment     Payment?  @relation(fields: [paymentId], references: [id])
}

model Payment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId  String   @db.ObjectId
  client    Client   @relation(fields: [clientId], references: [id])
  amount    Int
  subscription String
  method    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  startDate DateTime
  endDate   DateTime
  nextPaymentDate DateTime
  paymentDate DateTime?
  paymentStatus String?
  date      DateTime @default(now())
  userId    String   @db.ObjectId // Add userId to payments
  user      User     @relation(fields: [userId], references: [id])
  historics Historic[] // Added relation to Historic
  notifications   Notification[] // Added relation to Notification
}

model Historic {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  action      String    // e.g., "CREATE", "UPDATE", "DELETE"
  entityType  String    // "CLIENT" or "PAYMENT"
  entityId    String    @db.ObjectId // ID of the client or payment
  oldData     Json?     // Previous state of the record (for updates)
  newData     Json?     // New state of the record
  changedBy   String    @db.ObjectId // User who made the change
  user        User      @relation(fields: [changedBy], references: [id])
  createdAt   DateTime  @default(now())
  description String?   // Optional human-readable description

 // Optional relations to Client and Payment
  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  paymentId   String?  @db.ObjectId
  payment     Payment? @relation(fields: [paymentId], references: [id])
}

// NextAuth required models
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}