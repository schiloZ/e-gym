generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL_LOCAL")
}

model SuperAdmin {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  password      String
  createdAt     DateTime  @default(now())
}

model Company {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  name                  String    // The company name
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  users                 User[]    // Relation to users associated with this company
  clients               Client[]  // Relation to clients associated with this company
  bills                 Bill[]    // Relation to bills associated with this company
  payments              Payment[] // Relation to payments associated with this company
  notifications         Notification[] // Relation to notifications associated with this company
  historics             Historic[]    // Relation to historic entries associated with this company
  location              String?   // Optional location of the company
  subscriptionType      String?   @default("free") // e.g., "free", "premium", "enterprise"
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?

  // Tracking limits
  clientRegistrationCount Int @default(0)
  maxClientRegistrations  Int @default(5)
  paymentCount            Int @default(0)
  maxPayments             Int @default(20)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  password      String
  role          String    @default("coach") // Options: "manager" or "coach"
  companyId     String    @db.ObjectId     // Required link to Company (every user belongs to a company)
  company       Company   @relation(fields: [companyId], references: [id])
  createdAt     DateTime  @default(now())
  clients       Client[]
  sessions      Session[]
  accounts      Account[]
  payments      Payment[]
  historics     Historic[]
  notifications Notification[]
  bills         Bill[]
}

model Bill {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  amount      Int
  date        DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  companyId   String?  @db.ObjectId
  company     Company? @relation(fields: [companyId], references: [id])
  historics   Historic[] @relation("HistoricBill")
}

model Client {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  phone            String?
  email            String?   @unique
  registrationDate DateTime  @default(now())
  imagePath        String?   // Optional Cloudflare image URL (e.g., "https://images.cloudflare.com/client-id/image-id")
  payments         Payment[]
  userId           String    @db.ObjectId
  user             User      @relation(fields: [userId], references: [id])
  companyId        String?   @db.ObjectId
  company          Company?  @relation(fields: [companyId], references: [id])
  historics        Historic[]
  notifications    Notification[]

  // Medical Information
  height           Float?    // Height in centimeters (e.g., 175.5)
  weight           Float?    // Weight in kilograms (e.g., 70.2)
  age              Int?      // Age in years
  medicalConditions String?  // JSON string or comma-separated (e.g., "diabetes,asthma")
  allergies        String?  // JSON string or comma-separated (e.g., "peanuts,dust")
  injuries         String?  // JSON string or comma-separated (e.g., "knee surgery 2023")
  medications      String?  // JSON string or comma-separated (e.g., "metformin")
  bloodPressure    String?  // Format: "systolic/diastolic" (e.g., "120/80")

  // Body Goals
  targetWeight     Float?    // Target weight in kilograms (e.g., 65.0)
  fitnessGoal      String?   // E.g., "weight loss", "muscle gain"
  targetBodyFat    Float?    // Target body fat percentage (e.g., 15.0)
  goalMilestone    DateTime? // Date to achieve the goal (e.g., "2025-07-01")
}

model Notification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  companyId   String?   @db.ObjectId     // Link to Company
  company     Company?  @relation(fields: [companyId], references: [id])
  clientId    String?   @db.ObjectId
  client      Client?   @relation(fields: [clientId], references: [id])
  paymentId   String?   @db.ObjectId
  payment     Payment?  @relation(fields: [paymentId], references: [id])
}

model Payment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId        String   @db.ObjectId
  client          Client   @relation(fields: [clientId], references: [id])
  amount          Int
  subscription    String
  method          String
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  startDate       DateTime
  endDate         DateTime
  nextPaymentDate DateTime
  paymentDate     DateTime?
  paymentStatus   String?
  date            DateTime @default(now())
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])
  companyId       String?  @db.ObjectId
  company         Company? @relation(fields: [companyId], references: [id])
  historics       Historic[]
  notifications   Notification[]
}

model Historic {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  action      String
  entityType  String
  entityId    String    @db.ObjectId
  oldData     Json?
  newData     Json?
  changedBy   String    @db.ObjectId
  user        User?      @relation(fields: [changedBy], references: [id])
  companyId   String?   @db.ObjectId     // Link to Company
  company     Company?  @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  description String?
  clientId    String?   @db.ObjectId
  client      Client?   @relation(fields: [clientId], references: [id])
  paymentId   String?   @db.ObjectId
  payment     Payment?  @relation(fields: [paymentId], references: [id])
  billId      String?   @db.ObjectId
  bill        Bill?     @relation("HistoricBill", fields: [billId], references: [id])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}